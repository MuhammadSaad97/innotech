rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /contacts/{docId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'message', 'status', 'createdAt', 'updatedAt'])
        && request.resource.data.name is string
        && request.resource.data.message is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.message.size() >= 10
        && request.resource.data.status == 'new'
        && (
          (request.resource.data.phone is string && request.resource.data.phone.size() >= 7)
          || (request.resource.data.email is string && request.resource.data.email.matches('^.+@.+\\..+$'))
        );
      allow read, update, delete: if false;
    }
  }
}
